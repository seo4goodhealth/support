<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Screen Share Mobile</title>
    <style>
        :root {
            --primary: #2563eb;
            --bg: #f3f4f6;
            --card-bg: #ffffff;
            --text: #1f2937;
        }
        * { box-sizing: border-box; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
        body { margin: 0; padding: 20px; background-color: var(--bg); color: var(--text); display: flex; flex-direction: column; align-items: center; min-height: 100vh; }
        h1 { font-size: 1.5rem; text-align: center; margin-bottom: 20px; }
        .container { width: 100%; max-width: 500px; background: var(--card-bg); padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .section { display: none; flex-direction: column; gap: 15px; }
        .section.active { display: flex; }
        button { width: 100%; padding: 15px; border: none; border-radius: 8px; background-color: var(--primary); color: white; font-size: 1rem; font-weight: bold; cursor: pointer; transition: 0.2s; }
        button:disabled { background-color: #9ca3af; cursor: not-allowed; }
        button:hover:enabled { background-color: #1d4ed8; }
        input { width: 100%; padding: 15px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 1rem; }
        #status { text-align: center; font-size: 0.9rem; color: #6b7280; margin-top: 10px; min-height: 1.2em; }
        #videoContainer { width: 100%; margin-top: 15px; border-radius: 8px; overflow: hidden; background: #000; aspect-ratio: 16/9; display: none; }
        video { width: 100%; height: 100%; object-fit: contain; }
        .tabs { display: flex; margin-bottom: 20px; border-bottom: 2px solid #e5e7eb; }
        .tab { flex: 1; padding: 10px; text-align: center; cursor: pointer; font-weight: bold; color: #6b7280; }
        .tab.active { color: var(--primary); border-bottom: 3px solid var(--primary); }
        .id-box { background: #e0e7ff; padding: 10px; border-radius: 6px; text-align: center; font-family: monospace; font-size: 1.2rem; font-weight: bold; word-break: break-all; cursor: pointer; }
        .label { font-size: 0.9rem; color: #4b5563; }
    </style>
</head>
<body>

    <h1>📱 Compartir Pantalla</h1>
    
    <div class="container">
        <div class="tabs">
            <div class="tab active" id="tab-emit" onclick="switchTab('emit')">Emitir</div>
            <div class="tab" id="tab-watch" onclick="switchTab('watch')">Ver</div>
        </div>

        <!-- SECCIÓN EMISOR -->
        <div class="section active" id="section-emit">
            <button id="startShareBtn">Iniciar Transmisión</button>
            <div id="emitInfo" style="display:none;">
                <div class="label">Comparte este código con el otro dispositivo:</div>
                <div class="id-box" id="myId">Generando...</div>
                <div id="status">Esperando a que se conecten...</div>
            </div>
        </div>

        <!-- SECCIÓN RECEPTOR -->
        <div class="section" id="section-watch">
            <div class="label">Ingresa el código del emisor:</div>
            <input type="text" id="remoteId" placeholder="Pega el código aquí">
            <button id="connectBtn">Conectar y Ver</button>
            <div id="videoContainer">
                <video id="remoteVideo" autoplay playsinline></video>
            </div>
        </div>
    </div>

    <!-- Librería PeerJS -->
    <script src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js"></script>
    <script>
        let peer = null;
        let currentCall = null;

        // Cambiar de pestaña
        function switchTab(role) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
            
            if (role === 'emit') {
                document.getElementById('tab-emit').classList.add('active');
                document.getElementById('section-emit').classList.add('active');
            } else {
                document.getElementById('tab-watch').classList.add('active');
                document.getElementById('section-watch').classList.add('active');
            }
        }

        // LÓGICA DEL EMISOR
        document.getElementById('startShareBtn').addEventListener('click', async () => {
            try {
                // Solicitar compartir pantalla / pestaña
                const stream = await navigator.mediaDevices.getDisplayMedia({ video: true, audio: true });
                
                document.getElementById('startShareBtn').style.display = 'none';
                document.getElementById('emitInfo').style.display = 'block';

                // Inicializar PeerJS
                peer = new Peer();

                peer.on('open', (id) => {
                    document.getElementById('myId').innerText = id;
                });

                // Cuando alguien nos llama
                peer.on('call', (call) => {
                    currentCall = call;
                    call.answer(stream); // Respondemos con nuestra pantalla
                    document.getElementById('status').innerText = '¡Conectado! Transmisión en curso.';
                });

                // Si el usuario deja de compartir desde el navegador
                stream.getVideoTracks()[0].onended = () => {
                    alert("Transmisión detenida.");
                    if (currentCall) currentCall.close();
                    location.reload();
                };

            } catch (err) {
                console.error("Error al obtener la pantalla:", err);
                alert("Debes permitir el acceso a la pantalla para transmitir.");
            }
        });

        // LÓGICA DEL RECEPTOR
        document.getElementById('connectBtn').addEventListener('click', () => {
            const remoteId = document.getElementById('remoteId').value.trim();
            if (!remoteId) {
                alert("Ingresa un código válido.");
                return;
            }

            document.getElementById('connectBtn').disabled = true;
            document.getElementById('connectBtn').innerText = "Conectando...";

            // Inicializar PeerJS
            peer = new Peer();

            peer.on('open', () => {
                // Llamar al emisor. 
                // Usamos un stream vacío (Canvas) porque WebRTC móvil requiere enviar algo de media en algunos casos,
                // pero en realidad solo queremos RECIBIR.
                const emptyCanvas = document.createElement('canvas');
                const fakeStream = emptyCanvas.captureStream();
                
                const call = peer.call(remoteId, fakeStream);
                currentCall = call;

                call.on('stream', (remoteStream) => {
                    // Mostrar el video recibido
                    const video = document.getElementById('remoteVideo');
                    video.srcObject = remoteStream;
                    document.getElementById('videoContainer').style.display = 'block';
                    document.getElementById('connectBtn').style.display = 'none';
                });

                call.on('error', (err) => {
                    console.error(err);
                    alert("Error al conectar. Verifica el código o si el emisor cerró la conexión.");
                    location.reload();
                });
            });
        });
    </script>
</body>
</html>
